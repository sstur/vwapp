# Mobile app env. Copy to `app/.env` (gitignored) and fill in.

# --- Bundled into the client (EXPO_PUBLIC_ prefix) ---
# Your InstantDB app id (same app as backend's INSTANT_APP_ID).
EXPO_PUBLIC_INSTANT_APP_ID=your-instant-app-id
# Your deployed Worker URL. Required for published builds; in local dev with the
# Metro server running it auto-targets the Worker on the same host (port 8787).
EXPO_PUBLIC_API_URL=https://vwapp-api.your-subdomain.workers.dev/rpc

# --- Config-time only (read by app.config.ts; never bundled) ---
# Needed for EAS Update / publishing to your own Expo account.
EXPO_OWNER=your-expo-account
EAS_PROJECT_ID=your-eas-project-uuid
IOS_BUNDLE_IDENTIFIER=com.yourname.vwapp
# App Store Connect app id (numeric, from the app's ASC URL); read by eas.json's
# $ASC_APP_ID for `eas submit`. Only needed to ship to TestFlight/App Store.
ASC_APP_ID=your-asc-app-id
