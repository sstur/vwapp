{
  "name": "@vwapp/mobile",
  "main": "expo-router/entry",
  "version": "1.0.21",
  "scripts": {
    "start": "expo start",
    "ios": "expo start --ios",
    "android": "expo start --android",
    "update": "set -a; [ -f .env ] && . ./.env; set +a; npx -y eas-cli update --branch main --environment production",
    "publish:ios": "set -a; [ -f .env ] && . ./.env; set +a; node scripts/with-asc-app-id.mts npx -y eas-cli build --platform ios --profile production --non-interactive --auto-submit --no-wait",
    "submit:ios": "set -a; [ -f .env ] && . ./.env; set +a; node scripts/with-asc-app-id.mts npx -y eas-cli submit --platform ios --latest --profile production --non-interactive --no-wait",
    "version": "node scripts/bump-version.mts",
    "typecheck": "tsc --noEmit && tsc --noEmit -p scripts/tsconfig.json",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "@expo/ui": "~56.0.18",
    "@instantdb/react-native": "^1.0.46",
    "@orpc/client": "^1.14.5",
    "@orpc/contract": "^1.14.5",
    "@orpc/tanstack-query": "^1.14.5",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/netinfo": "12.0.1",
    "@tamagui/config": "^2.1.0",
    "@tamagui/lucide-icons-2": "^2.1.0",
    "@tamagui/themes": "^2.1.0",
    "@tanstack/react-query": "^5.101.0",
    "@vwapp/contract": "workspace:*",
    "@vwapp/db": "workspace:*",
    "expo": "~56.0.12",
    "expo-audio": "~56.0.12",
    "expo-constants": "~56.0.18",
    "expo-crypto": "~56.0.4",
    "expo-linking": "~56.0.14",
    "expo-router": "~56.2.11",
    "expo-secure-store": "~56.0.4",
    "expo-splash-screen": "~56.0.10",
    "expo-status-bar": "~56.0.4",
    "expo-symbols": "~56.0.6",
    "expo-system-ui": "~56.0.5",
    "expo-updates": "~56.0.19",
    "react": "19.2.3",
    "react-native": "0.85.3",
    "react-native-gesture-handler": "~2.31.2",
    "react-native-get-random-values": "~1.11.0",
    "react-native-keyboard-controller": "1.21.6",
    "react-native-reanimated": "4.3.1",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-svg": "15.15.4",
    "react-native-worklets": "0.8.3",
    "tamagui": "^2.1.0"
  },
  "devDependencies": {
    "@types/react": "~19.2.2",
    "typescript": "^6.0.3"
  },
  "private": true
}
