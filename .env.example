# Root env — your real myVW login. Copy to `.env` (gitignored) and fill in.
# Used by the PoC/smoke scripts and to drive simulator login tests.
#
# IMPORTANT: this must be a North America (myVW / legacy Car-Net) account.
# The EU CARIAD stack is not supported (see CLAUDE.md → VW protocol).
VW_USERNAME=you@example.com
VW_PASSWORD=your-myvw-password
VW_PIN=0000   # your 4-digit S-PIN (needed for lock/unlock and force-refresh)
