{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "vwapp-api",
  // No account_id pinned here so anyone can deploy to their own account: set
  // CLOUDFLARE_ACCOUNT_ID in the environment before `wrangler deploy` (wrangler
  // reads it natively). Each deployer gets vwapp-api.<their-subdomain>.workers.dev.
  "main": "src/index.ts",
  "compatibility_date": "2026-06-01",
  "compatibility_flags": ["nodejs_compat"],
  "observability": { "enabled": true },
  // Poll VW for every stored account every minute (Cloudflare's finest cron
  // granularity); fresh snapshots land in InstantDB and stream to subscribed
  // apps, and this is the latency floor for derived notifications (TODO §4).
  // Plain rvs/ev status reads aren't the tsp-token-rate-limited endpoints, so
  // 1-min polling is safe. Crons don't fire on a clock in dev: `pnpm dev`
  // pairs wrangler with a curl loop ticking
  // "http://localhost:8787/cdn-cgi/handler/scheduled" every 60s.
  "triggers": { "crons": ["* * * * *"] },
}
