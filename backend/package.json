{
  "name": "@vwapp/backend",
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "pnpm run \"/^dev:/\"",
    "dev:worker": "wrangler dev --ip 0.0.0.0",
    "dev:cron": "while true; do sleep 60; curl -s -o /dev/null --max-time 50 \"http://localhost:8787/cdn-cgi/handler/scheduled\" || true; done",
    "deploy": "set -a; [ -f .env ] && . ./.env; set +a; wrangler deploy",
    "cf-typegen": "wrangler types",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "@instantdb/admin": "^1.0.46",
    "@orpc/server": "latest",
    "@vwapp/contract": "workspace:*",
    "@vwapp/db": "workspace:*",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@orpc/client": "^1.14.5",
    "wrangler": "latest"
  },
  "private": true
}
