# Deploy-time env for the Worker. Copy to `.env` (gitignored) and fill in.
# Auto-sourced by `pnpm --filter @vwapp/backend deploy` so wrangler targets
# your Cloudflare account. (This is NOT a Worker secret — secrets live in
# .dev.vars and are pushed with `wrangler secret bulk`.)
CLOUDFLARE_ACCOUNT_ID=your-cloudflare-account-id
